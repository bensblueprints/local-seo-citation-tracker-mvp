# Citewatch configuration
PORT=5363
ADMIN_PASSWORD=change-me

# Where the SQLite database lives (defaults to ./data/citewatch.db)
# DB_PATH=./data/citewatch.db

# Optional: bring-your-own-key Google Places auto-pull for the Google Business
# Profile directory ONLY. Leave unset and the feature stays disabled — every
# other directory is a manual audit by design (no scraping, no ToS drama).
# GOOGLE_PLACES_API_KEY=

# Advanced/testing: override the Places API base URL (used by the smoke test
# to point at a local fixture server — never needed in normal use).
# PLACES_API_BASE=https://places.googleapis.com
